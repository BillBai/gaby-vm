# ----------------------------------------------------------------------------
# Build output (CMake)
# ----------------------------------------------------------------------------
# Out-of-tree build dirs. Covers `build/`, `build-debug/`, `build-release/`,
# CLion's `cmake-build-*/`, and Google-style `out/`.
build/
build-*/
cmake-build-*/
out/

# In-source CMake artifacts (only triggered if someone does an in-source build).
CMakeCache.txt
CMakeFiles/
CMakeScripts/
cmake_install.cmake
CTestTestfile.cmake
CPackConfig.cmake
CPackSourceConfig.cmake
Makefile
install_manifest.txt
compile_commands.json

# CTest run artifact: created in the working directory when `ctest` is invoked
# from outside the build tree (it writes `Testing/Temporary/LastTest.log`).
Testing/

# Ninja
.ninja_deps
.ninja_log

# ----------------------------------------------------------------------------
# Compiled artifacts
# ----------------------------------------------------------------------------
# Object files, archives, shared libs, and executables — matched at any depth.
*.o
*.obj
*.a
*.la
*.lo
*.so
*.so.*
*.dylib
*.dll
*.exe

# Default GCC/Clang output name when no `-o` flag is passed.
a.out

# Debug symbols
*.dSYM/
*.pdb
*.idb
*.ilk
*.map

# Linker artifacts
*.exp
*.lib

# ----------------------------------------------------------------------------
# Coverage / profiling
# ----------------------------------------------------------------------------
*.gcda
*.gcno
*.gcov
coverage/
*.profraw
*.profdata
lcov.info

# ----------------------------------------------------------------------------
# Xcode (iOS / macOS targets)
# ----------------------------------------------------------------------------
# Per-user state inside Xcode projects — never share these.
xcuserdata/
*.xcuserstate
*.xcworkspace/xcuserdata/
*.xcscheme
DerivedData/

# ----------------------------------------------------------------------------
# Swift Package Manager
# ----------------------------------------------------------------------------
# Transient SPM artifacts. `.build/` is the build/output dir; `.swiftpm/` holds
# per-user package state; `Package.resolved` pins dependency versions and is
# intentionally not tracked for a library package (consumers resolve their own).
.build/
.swiftpm/
Package.resolved

# ----------------------------------------------------------------------------
# IDE / editor
# ----------------------------------------------------------------------------
# .vscode/ is ignored by default to keep per-user editor state out of the
# repo, but shared debug/build configs (launch.json, tasks.json) are
# whitelisted so the project ships a working F5 experience for VSCode,
# Cursor, CodeBuddy, and other VSCode-derived editors.
.vscode/*
!.vscode/launch.json
!.vscode/tasks.json
.idea/
*.iml
.cache/
.ccls-cache/
.clangd/

# Editor backups and swap files
*~
*.swp
*.swo
.*.swp
.*.swo
*.bak
\#*\#
.\#*

# ----------------------------------------------------------------------------
# OS noise
# ----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ----------------------------------------------------------------------------
# Agent-tool machine-local overrides
# ----------------------------------------------------------------------------
# Shared OpenSpec scaffolding under .claude/, .cursor/, etc. is intentionally
# tracked. The patterns below let those same dirs hold per-user, per-machine
# state (sessions, caches, local permission grants) without polluting git.
**/settings.local.json
**/*.local.json
**/.session/

# ----------------------------------------------------------------------------
# WIP tooling
# ----------------------------------------------------------------------------
.antigravitycli/
.understand-anything/

# ----------------------------------------------------------------------------
# CI local-run artifacts (ci/ scripts emit these into the cwd by default)
# ----------------------------------------------------------------------------
/sizes.json
/bench.json
/pr-comment.md
/.ci-base/

# ----------------------------------------------------------------------------
# Misc
# ----------------------------------------------------------------------------
*.log
*.tmp
*.pid
core
